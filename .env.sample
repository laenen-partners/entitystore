ADDR=:3002
DATABASE_URL=postgres://postgres:postgres@localhost:5433/entitystore?sslmode=disable

# API authentication (comma-separated keys, empty = auth disabled)
API_KEYS=

# Rate limiting (per IP)
RATE_LIMIT=10
RATE_BURST=20

# CORS (comma-separated origins, empty = disabled)
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# Database connection pool
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_CONN_IDLE_TIME=30m

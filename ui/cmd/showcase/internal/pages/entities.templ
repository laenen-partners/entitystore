package pages

import "github.com/laenen-partners/entitystore/ui/cmd/showcase/internal/layouts"
import "github.com/laenen-partners/dsx/showcase"

templ Entities() {
	@layouts.Explorer(layouts.ExplorerProps{Title: "Entities", Path: "/entities"}) {
		<div class="space-y-6">
			<h2 class="text-2xl font-bold">Entities</h2>
			@showcase.Fragment("entity-list", "/fragments/entities")
		</div>
	}
}
